	journal = {Rural Sustainability Research},
	author = {Sharma, Shubham and Walia, Gurleen Kaur and Singh, Kanwalpreet and Batra, Vanshika and Sekhon, Amandeep Kaur and Kumar, Aniket and Rawal, Kirti and Ghai, Deepika},
	month = dec,
	year = {2024},
	pages = {63--77},
}

